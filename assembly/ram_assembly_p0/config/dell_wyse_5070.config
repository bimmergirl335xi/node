# Dell Wyse 5070 first-proof hardware-era fragment.
# The resolver also records actual local CPU and PCI evidence; this file is not
# a claim that every 5070 SKU contains every device listed here.
CONFIG_DRM_I915=y
CONFIG_INTEL_IDLE=y
CONFIG_X86_INTEL_PSTATE=y
CONFIG_PINCTRL_GEMINILAKE=y
CONFIG_MMC=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PCI=y
CONFIG_R8169=y
CONFIG_E1000E=y
CONFIG_IGB=y
